# Casper Platform — Environment Variables
# Copy to .env and fill in values for local development.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgres://casper:casper@localhost:5432/casper
DATABASE_OWNER_URL=postgres://casper:casper@localhost:5432/casper

# ── Auth (production only — dev mode uses ephemeral keys) ─────────
# CASPER_SIGNING_KEY_FILE=/run/secrets/casper_signing_key
# CASPER_MASTER_KEY_FILE=/run/secrets/casper_master_key

# ── Server ────────────────────────────────────────────────────────
CASPER_CONFIG=config/casper-server.yaml
RUST_LOG=info,sqlx=warn

# ── SearXNG (web search tool) ────────────────────────────────────
SEARXNG_BASE_URL=http://localhost:8080

# ── Test mode (disables real LLM calls in integration tests) ──────
# CASPER_TEST_MODE=1
